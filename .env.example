# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173

# Database — leave BUNNY_DATABASE_URL unset for local dev (uses file:dev.db)
BUNNY_DATABASE_URL=
BUNNY_DATABASE_AUTH_TOKEN=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@hopsell.shop

# Bunny Storage (S3-compatible) — used for both presigned uploads and downloads
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_REGION=de
# CDN base URL is required by @bunny.net/upload but unused for paid downloads.
# Set it to your pull zone if you have one, e.g. https://my-zone.b-cdn.net
BUNNY_CDN_BASE=https://example.invalid

# Stripe Connect
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=

# Pricing
PLATFORM_FEE_BPS=500
